{
  "version": "2.0.0",
  "project": "vci-skill-cuongbx",
  "description": "Main SDLC PRD/Spec skill. Companion zones live in separate repos.",
  "main_skill": {
    "name": "vci-skill-cuongbx",
    "path": "SKILL.md",
    "description": "10-mode SDLC PRD/Spec generator (BA/Dev/QA/PM/Shared)"
  },
  "local_zones": {
    "vci": {
      "description": "Support skills tightly coupled với main skill (11 skills)",
