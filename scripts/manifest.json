      "tracked": true
    }
  },
  "companion_repos": {
    "claudekit": {
      "description": "ClaudeKit Engineer core dev tools (~1389 skills)",
      "url": "https://github.com/cuongbx/skills-claudekit.git",
      "install_to": ".claude/skills/claudekit"
    },
    "xia": {
      "description": "Feature heist — port from external repos (1 skill)",
      "url": "https://github.com/cuongbx/skills-xia.git",
      "install_to": ".claude/skills/xia"
    },
    "others": {
      "description": "Antigravity UI/design skills (9 skills)",
      "url": "https://github.com/cuongbx/skills-others.git",
      "install_to": ".claude/skills/others"
    }
  },
  "install_command": "bash scripts/install-companion.sh all"
}
